rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /listing-images/{userId}/{listingId}/{fileName} {
      function signedInOwner() {
        return request.auth != null
          && request.auth.uid == userId
          && request.auth.token.email_verified == true;
      }

      function listingPath() {
        return /databases/(default)/documents/listings/$(listingId);
      }

      function listingIsEditable() {
        return !firestore.exists(listingPath())
          || (
            firestore.get(listingPath()).data.ownerId == userId
            && firestore.get(listingPath()).data.status in ['pending', 'draft']
          );
      }

      allow read: if true;
      allow create: if signedInOwner()
        && listingIsEditable()
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow update: if false;
      allow delete: if signedInOwner()
        && listingIsEditable();
    }
  }
}
